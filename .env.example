# Everything below is OPTIONAL. SourceFetch runs with none of it set:
# it uses an offline hashing embedder and returns the top retrieved passages.

# Add a key to turn on grounded, synthesized answers (and the grounding eval).
ANTHROPIC_API_KEY=
# Generation model (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Embedding backend: "hashing" (default, offline) or "sentence-transformers" (semantic, HF).
# Changing this requires re-running scripts/ingest.py.
# EMBEDDINGS_BACKEND=sentence-transformers
# ST_MODEL=all-MiniLM-L6-v2
